---
import WikiLayout from '../layouts/WikiLayout.astro';
---
<WikiLayout title="Search">
  <div class="wiki-content" data-pagefind-ignore>
    <h1 class="firstHeading">Search results</h1>
    <p class="subtitle" id="search-status">Loading search index…</p>

    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <div id="search" style="margin-top:16px"></div>

    <p style="margin-top:24px; font-size:13px; color:var(--color-base--subtle)">
      Search covers article text only. To browse rather than search, see <a href="/special/all-pages">All pages</a>, the <a href="/sources">Source index</a>, or the topic categories in the sidebar.
    </p>
  </div>

  {/* Load pagefind UI via plain <script src>, the pattern pagefind itself
      recommends. Avoids the dynamic-import fragility we hit before. */}
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    (function () {
      var params = new URLSearchParams(window.location.search);
      var initial = params.get('q') || '';
      var status = document.getElementById('search-status');

      if (typeof PagefindUI === 'undefined') {
        status.textContent =
          'Search index not available. (If you are viewing this on the live site, please refresh — the index may still be loading.)';
        return;
      }

      new PagefindUI({
        element: '#search',
        showImages: false,
        showSubResults: true,
        resetStyles: false,
      });

      status.textContent = initial
        ? 'Showing results for “' + initial + '”'
        : 'Type a query to search.';

      if (initial) {
        // Wait a tick for PagefindUI to wire its input, then prefill.
        setTimeout(function () {
          var input = document.querySelector('#search input');
          if (input) {
            input.value = initial;
            input.dispatchEvent(new Event('input', { bubbles: true }));
            input.focus();
          }
        }, 50);
      }
    })();
  </script>
</WikiLayout>
