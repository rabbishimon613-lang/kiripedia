---
import WikiLayout from '../layouts/WikiLayout.astro';
import { getCollection } from 'astro:content';
const articles = await getCollection('articles');
const sources = await getCollection('sources');
const count = articles.length;

const slugOf = (a) => a.id.replace(/\.mdx?$/, '');

// ---------- Cool numbers strip ----------
// Computed at build time so it always stays in sync with the corpus.

// Sum total transcript duration across all source recordings.
function parseDuration(d) {
  if (!d) return 0;
  const parts = String(d).split(':').map(Number);
  if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
  if (parts.length === 2) return parts[0] * 60 + parts[1];
  return parts[0] || 0;
}
const totalSourceSeconds = sources.reduce(
  (acc, s) => acc + parseDuration(s.data.duration),
  0
);
const totalSourceHours = Math.round(totalSourceSeconds / 3600);

// Approximate word count: sum of MDX body lengths divided by avg word length (5.1).
// Pagefind reports its own number; this is the corpus measurement.
const totalWords = articles.reduce(
  (acc, a) => acc + Math.round((a.body ?? '').length / 5.5),
  0
);

// Count people, agencies, places by primary category (or first category).
function categoryOf(a) {
  const cats = a.data.categories ?? (a.data.category ? [a.data.category] : []);
  return cats[0] ?? null;
}
const counts = {};
for (const a of articles) {
  const c = categoryOf(a);
  if (!c) continue;
  counts[c] = (counts[c] ?? 0) + 1;
}
const peopleCount = counts.People ?? 0;
const placesCount = counts.Places ?? 0;
const organizationsCount = counts.Organizations ?? 0;
const programsCount = counts.Programs ?? 0;
const tradecraftCount = counts.Tradecraft ?? 0;
const eventsCount = counts.Events ?? 0;

// Count distinct countries mentioned via wiki-style links to known country slugs.
// A small curated list — anything else gets ignored. Avoids false positives.
const COUNTRY_SLUGS = new Set([
  'afghanistan','pakistan','iran','iraq','yemen','saudi-arabia','israel',
  'jordan','lebanon','libya','syria','egypt','cuba','united-arab-emirates',
  'bahrain','indonesia','greece','russia','china','north-korea','cambodia',
  'thailand','india','romania','kuwait','mexico','spain','united-kingdom',
  'france','germany','poland','lithuania','vietnam','korea',
  'south-korea','dubai',
]);
const countryMentions = new Set();
for (const a of articles) {
  const body = a.body ?? '';
  for (const m of body.matchAll(/\(\/wiki\/([a-z0-9-]+)\)/g)) {
    if (COUNTRY_SLUGS.has(m[1])) countryMentions.add(m[1]);
  }
}
const countriesCount = countryMentions.size;

// Citation count — every <Cite s=... /> in every article body.
let citationsCount = 0;
for (const a of articles) {
  const body = a.body ?? '';
  citationsCount += (body.match(/<Cite\s+s=/g) ?? []).length;
}

// ---------- Featured-article-of-the-day ----------
// Pinned features take precedence until their `until` date (inclusive, UTC).
// After all pins expire, a deterministic daily rotation kicks in: every UTC day
// picks the same article for every visitor, but the pick changes day-over-day.
const pinnedFeatured = [
  { slug: 'hummus', until: '2026-05-27' }, // Hummus pinned through Wed May 27, 2026
];
const rotationPool = articles.map(slugOf).sort();

function pickFeatured(today /* "YYYY-MM-DD" */) {
  for (const p of pinnedFeatured) {
    if (today <= p.until) return p.slug;
  }
  const [y, m, d] = today.split('-').map(Number);
  const dayNumber = Math.floor(Date.UTC(y, m - 1, d) / 86_400_000);
  return rotationPool[dayNumber % rotationPool.length] ?? slugOf(articles[0]);
}

const today = new Date().toISOString().slice(0, 10);
const todayMD = today.slice(5);
const initialSlug = pickFeatured(today);
const initialArticle =
  articles.find((a) => slugOf(a) === initialSlug) ?? articles[0];
const initialImage = initialArticle.data.infobox?.image ?? '/logo.png';

// Lightweight catalog the client script uses to repaint the featured box.
const articleCatalog = articles.map((a) => ({
  slug: slugOf(a),
  title: a.data.title,
  summary: a.data.summary ?? '',
  image: a.data.infobox?.image ?? '/logo.png',
}));

// ---------- On this day ----------
// Aggregate every article's `events` array. Each event becomes
// { date, mmdd, year, description, article_slug, article_title }.
// We render today's matches (sorted newest year first), with a fallback
// message if none.
const allEvents = [];
for (const a of articles) {
  const evs = a.data.events ?? [];
  for (const e of evs) {
    const parts = e.date.split('-'); // YYYY, YYYY-MM, or YYYY-MM-DD
    const year = parts[0];
    const month = parts[1] ?? '';
    const day = parts[2] ?? '';
    const mmdd = month && day ? `${month}-${day}` : null;
    allEvents.push({
      date: e.date,
      year,
      mmdd,
      month_only: !day && month ? `${year}-${month}` : null,
      description: e.description,
      slug: slugOf(a),
      title: a.data.title,
    });
  }
}
// Today's events: exact MM-DD matches first; fall back to month-only entries
// for the current month if no day-precise match exists.
let todayEvents = allEvents.filter((e) => e.mmdd === todayMD);
if (todayEvents.length === 0) {
  todayEvents = allEvents.filter((e) =>
    e.month_only && e.month_only.slice(5) === todayMD.slice(0, 2)
  );
}
todayEvents.sort((a, b) => Number(b.year) - Number(a.year));

// Inline Markdown renderer for event descriptions (same shape as Infobox)
function mdLite(s) {
  if (s == null) return '';
  return String(s)
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
    .replace(/\*([^*]+)\*/g, '<em>$1</em>');
}

// ---------- Did you know … ----------
const allDyk = [];
for (const a of articles) {
  const items = a.data.dyk ?? [];
  for (const text of items) {
    allDyk.push({ text, slug: slugOf(a), title: a.data.title });
  }
}
// Pick 3 deterministically based on today's date so the page is stable across the day.
function pickDyk(today, pool, count = 3) {
  if (pool.length === 0) return [];
  const [y, m, d] = today.split('-').map(Number);
  const seed = Math.floor(Date.UTC(y, m - 1, d) / 86_400_000);
  const picked = [];
  const used = new Set();
  for (let i = 0; i < count && i < pool.length; i++) {
    let idx = (seed * 31 + i * 97) % pool.length;
    // Skip if already picked (shouldn't happen often given the modular hash)
    while (used.has(idx)) idx = (idx + 1) % pool.length;
    used.add(idx);
    picked.push(pool[idx]);
  }
  return picked;
}
const todayDyk = pickDyk(today, allDyk, 3);

// ---------- Today, formatted for display ----------
const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const todayDisplay = `${monthNames[Number(today.slice(5,7)) - 1]} ${Number(today.slice(8,10))}`;
---
<WikiLayout title="Main Page">
  <div class="wiki-content">
    <div class="mainpage-welcome">
      <h1>Welcome to <strong>KiriPedia</strong>,</h1>
      <p>the free encyclopedia of the world as seen through John Kiriakou's eyes.</p>
      <p style="margin-top:6px">Drawn from his publicly available interviews, podcasts, and short-form video appearances.</p>
    </div>

    <div class="stats-strip">
      <div class="stat"><span class="stat-num">{count.toLocaleString()}</span><span class="stat-label">articles</span></div>
      <div class="stat"><span class="stat-num">{totalWords.toLocaleString()}</span><span class="stat-label">words written</span></div>
      <div class="stat"><span class="stat-num">{sources.length}</span><span class="stat-label">source recordings</span></div>
      <div class="stat"><span class="stat-num">{totalSourceHours}</span><span class="stat-label">hours transcribed</span></div>
      <div class="stat"><span class="stat-num">{citationsCount.toLocaleString()}</span><span class="stat-label">cited timestamps</span></div>
      <div class="stat"><span class="stat-num">{peopleCount}</span><span class="stat-label">people</span></div>
      <div class="stat"><span class="stat-num">{organizationsCount}</span><span class="stat-label">organizations</span></div>
      <div class="stat"><span class="stat-num">{placesCount}</span><span class="stat-label">places</span></div>
      <div class="stat"><span class="stat-num">{programsCount}</span><span class="stat-label">programs</span></div>
      <div class="stat"><span class="stat-num">{tradecraftCount}</span><span class="stat-label">tradecraft</span></div>
      <div class="stat"><span class="stat-num">{eventsCount}</span><span class="stat-label">events</span></div>
    </div>

    <div class="mainpage-grid mainpage-grid-3">
      <section class="mainpage-box tfa">
        <h2>From today's featured article</h2>
        <p style="float:left; margin-right:12px;">
          <a id="featured-thumb-link" href={`/wiki/${initialSlug}`}>
            <img id="featured-thumb-img" src={initialImage} alt="" width="120" style="border:1px solid var(--color-border-subtle); padding:2px; background:transparent; max-height:160px; object-fit:cover" />
          </a>
        </p>
        <p>
          <strong><a id="featured-title-link" href={`/wiki/${initialSlug}`}>{initialArticle.data.title}</a></strong> — <span id="featured-summary">{initialArticle.data.summary}</span> <a id="featured-full-link" href={`/wiki/${initialSlug}`}>(Full article…)</a>
        </p>
      </section>

      <section class="mainpage-box dyk">
        <h2>Did you know …</h2>
        {todayDyk.length > 0 ? (
          <ul>
            {todayDyk.map((d) => (
              <li set:html={mdLite(d.text)} />
            ))}
          </ul>
        ) : (
          <p><em>No Did-you-know entries yet. Add a <code>dyk:</code> array to any article's frontmatter to seed this section.</em></p>
        )}
      </section>

      <section class="mainpage-box otd">
        <h2>On this day — {todayDisplay}</h2>
        {todayEvents.length > 0 ? (
          <ul>
            {todayEvents.map((e) => (
              <li>
                <strong>{e.year}</strong> — <span set:html={mdLite(e.description)} /> {' '}
                <a href={`/wiki/${e.slug}`} style="font-size:12px; color:var(--color-base--subtle)">[{e.title}]</a>
              </li>
            ))}
          </ul>
        ) : (
          <p><em>No events recorded for today in KiriPedia's corpus yet. See the <a href="/on-this-day">full year-spanning calendar</a> for what we do have.</em></p>
        )}
        <p style="font-size:12px; margin-top:8px"><a href="/on-this-day">Browse the full calendar →</a></p>
      </section>
    </div>

    <section class="mainpage-box" style="margin-top:12px">
      <h2>Browse by topic</h2>
      <p>
        <a href="/category/people">People</a> ·
        <a href="/category/organizations">Organizations</a> ·
        <a href="/category/places">Places</a> ·
        <a href="/category/programs">Programs</a> ·
        <a href="/category/tradecraft">Tradecraft</a> ·
        <a href="/category/events">Events</a>
      </p>
    </section>
  </div>

  <!-- Client-side refresh of the featured article so the rotation stays correct
       between Vercel builds. No-op if the build-time pick matches today's pick. -->
  <script is:inline define:vars={{ pinnedFeatured, rotationPool, articleCatalog, initialSlug }}>
    (function () {
      function todayUTC() {
        return new Date().toISOString().slice(0, 10);
      }
      function pickFeatured(today) {
        for (const p of pinnedFeatured) {
          if (today <= p.until) return p.slug;
        }
        const [y, m, d] = today.split('-').map(Number);
        const dayNumber = Math.floor(Date.UTC(y, m - 1, d) / 86400000);
        return rotationPool[dayNumber % rotationPool.length] ?? articleCatalog[0].slug;
      }
      const todaySlug = pickFeatured(todayUTC());
      if (todaySlug === initialSlug) return;
      const meta = articleCatalog.find((a) => a.slug === todaySlug);
      if (!meta) return;
      const titleLink = document.getElementById('featured-title-link');
      const thumbLink = document.getElementById('featured-thumb-link');
      const thumbImg = document.getElementById('featured-thumb-img');
      const fullLink = document.getElementById('featured-full-link');
      const summary = document.getElementById('featured-summary');
      if (titleLink) {
        titleLink.href = '/wiki/' + meta.slug;
        titleLink.textContent = meta.title;
      }
      if (thumbLink) thumbLink.href = '/wiki/' + meta.slug;
      if (thumbImg) thumbImg.src = meta.image;
      if (fullLink) fullLink.href = '/wiki/' + meta.slug;
      if (summary) summary.textContent = meta.summary;
    })();
  </script>
</WikiLayout>
