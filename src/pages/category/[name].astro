---
import WikiLayout from '../../layouts/WikiLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('articles');
  const cats = new Set();
  for (const a of all) {
    const list = a.data.categories || (a.data.category ? [a.data.category] : []);
    list.forEach((c) => cats.add(c.toLowerCase()));
  }
  // ensure top-level categories always exist even if empty
  ['people','agencies','operations','events','concepts','cases','places'].forEach((c) => cats.add(c));
  return [...cats].map((name) => ({ params: { name } }));
}

const { name } = Astro.params;
const articles = await getCollection('articles');
const matching = articles.filter((a) => {
  const list = a.data.categories || (a.data.category ? [a.data.category] : []);
  return list.map((c) => c.toLowerCase()).includes(name);
});
const display = name.charAt(0).toUpperCase() + name.slice(1);
const SITE = 'https://www.kiripedia.org';

// CollectionPage + ItemList JSON-LD so Google understands this is a list
// page indexing N articles, not just a leaf doc.
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `Category: ${display}`,
  "description": `All KiriPedia articles in the ${display} category — sourced exclusively from John Kiriakou's public interviews and podcast appearances.`,
  "url": `${SITE}/category/${name}`,
  "inLanguage": "en",
  "isPartOf": { "@type": "WebSite", "name": "KiriPedia", "url": SITE },
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": matching.length,
    "itemListElement": matching.map((a, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${SITE}/wiki/${a.id.replace(/\.mdx?$/, '')}`,
      "name": a.data.title,
    })),
  },
};
---
<WikiLayout
  title={`Category: ${display}`}
  description={`${matching.length} KiriPedia articles in the ${display} category.`}
>
  <div class="wiki-content">
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    <h1 class="firstHeading">Category: {display}</h1>
    <p class="subtitle">{matching.length} articles in this category</p>
    {matching.length === 0 ? (
      <p><em>No articles yet in this category.</em></p>
    ) : (
      <ul>
        {matching.map((a) => (
          <li><a href={`/wiki/${a.id}`}>{a.data.title}</a>{a.data.summary && <> — <span style="color:var(--color-base--subtle)">{a.data.summary}</span></>}</li>
        ))}
      </ul>
    )}
  </div>
</WikiLayout>
