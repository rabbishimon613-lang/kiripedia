---
import WikiLayout from '../../layouts/WikiLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const stubs = articles
  .filter((a) => a.data.stub)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---
<WikiLayout title="Stubs">
  <div class="wiki-content">
    <h1 class="firstHeading">Stubs</h1>
    <p class="subtitle">Articles awaiting expansion as new source material is ingested</p>

    <article class="wiki-body">
      <p>
        A <em>stub</em> is an article that exists because the topic has been mentioned by Kiriakou in at least one source, but where the available material is too thin to support a full encyclopedic treatment. Stubs are expanded automatically as additional sources mention the same topic.
      </p>

      <p><strong>{stubs.length}</strong> stub{stubs.length === 1 ? '' : 's'} currently on KiriPedia.</p>

      {stubs.length === 0 ? (
        <p><em>No stubs at the moment.</em></p>
      ) : (
        <ul>
          {stubs.map((a) => {
            const cats = a.data.categories || (a.data.category ? [a.data.category] : []);
            return (
              <li style="padding:4px 0">
                <a href={`/wiki/${a.id.replace(/\.mdx?$/, '')}`}><strong>{a.data.title}</strong></a>
                {cats.length > 0 && <span style="font-size:12px; color:var(--color-base--subtle)"> · {cats.join(', ')}</span>}
                {a.data.summary && <div style="font-size:13px; color:var(--color-base--subtle); margin-top:2px">{a.data.summary}</div>}
              </li>
            );
          })}
        </ul>
      )}
    </article>
  </div>
</WikiLayout>
