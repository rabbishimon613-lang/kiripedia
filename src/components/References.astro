---
import { list, tsToSeconds, tsAnchor } from '../lib/citations.mjs';
import { getEntry } from 'astro:content';

const pathname = Astro.url.pathname;
const cites = list(pathname);

const enriched = await Promise.all(cites.map(async (c) => {
  const src = await getEntry('sources', c.s);
  const data = src?.data ?? {};
  const yt = data.videoId ? `https://www.youtube.com/watch?v=${data.videoId}&t=${tsToSeconds(c.t)}s` : null;
  return {
    ...c,
    show: data.show ?? c.s,
    title: data.title ?? '',
    date: data.date ?? '',
    yt,
    transcript: `/sources/${c.s}#${tsAnchor(c.t)}`,
  };
}));
---
{enriched.length > 0 && (
  <section class="references-section">
    <h2>References</h2>
    <ol class="references">
      {enriched.map((c) => (
        <li id={`cite-note-${c.n}`}>
          <a href={`#cite-ref-${c.n}`} class="cite-backlink" title="Jump back to citation">↑</a>
          {' '}
          <cite><em>{c.show}</em>{c.date && <>, {c.date}</>}</cite>
          {c.yt && <> — <a href={c.yt} target="_blank" rel="noopener">{c.t} on YouTube</a></>}
          {' · '}
          <a href={c.transcript}>Transcript</a>
        </li>
      ))}
    </ol>
  </section>
)}
