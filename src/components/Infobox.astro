---
const { title, image, imageCaption, data = {} } = Astro.props;
const entries = Object.entries(data);

// Convert inline Markdown link syntax [text](url) to HTML <a>, and *em* to <em>,
// so authors can write infobox values naturally. Everything else passes through.
function mdLite(s) {
  if (s == null) return '';
  return String(s)
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
    .replace(/\*([^*]+)\*/g, '<em>$1</em>');
}
---
<aside class="infobox">
  <div class="infobox-title">{title}</div>
  {image && (
    <div class="infobox-image">
      <img src={image} alt={imageCaption || title} />
      {imageCaption && <div style="font-size:12px;margin-top:4px;color:var(--color-base--subtle)">{imageCaption}</div>}
    </div>
  )}
  {entries.length > 0 && (
    <table>
      <tbody>
        {entries.map(([k, v]) => (
          <tr><th>{k}</th><td set:html={mdLite(v)} /></tr>
        ))}
      </tbody>
    </table>
  )}
</aside>
