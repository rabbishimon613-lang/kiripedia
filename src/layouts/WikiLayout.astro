---
import '../styles/wiki.css';
import Analytics from '@vercel/analytics/astro';
import SEO from '../components/SEO.astro';
const { title, description, image, type } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <SEO title={title} description={description} image={image} type={type} />
  <meta name="google-site-verification" content="JvKQVSSl8FDIvQ5B7Lpd2l6dur8qW-T-jm3rmUerB20" />
  <link rel="icon" href="/logo.png" />
  <link rel="apple-touch-icon" href="/logo.png" />
  <link rel="alternate" type="application/rss+xml" title="KiriPedia — recent articles" href="/rss.xml" />

  {/* Site-wide structured data: WebSite with SearchAction (gets sitelinks search box in Google) */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "KiriPedia",
    "alternateName": "Kiripedia",
    "url": "https://www.kiripedia.org",
    "description": "The free encyclopedia of the world as seen through John Kiriakou's eyes.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://www.kiripedia.org/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />
</head>
<body>
  <header class="wiki-header">
    <button class="menu-btn" aria-label="Menu" aria-expanded="false" aria-controls="wiki-sidebar">☰</button>
    <a href="/" class="logo-link">
      <img src="/logo.png" alt="KiriPedia" class="logo-img" />
      <span class="wordmark">
        <span class="name">Kiripedia</span>
        <span class="tagline">The Free Encyclopedia of John Kiriakou's World</span>
      </span>
    </a>
    <form class="search" role="search" action="/search" method="get" autocomplete="off">
      <input type="search" name="q" id="header-search-input" placeholder="Search KiriPedia" autocomplete="off" />
      <div id="header-search-suggest" class="search-suggest" hidden></div>
    </form>
  </header>

  <div class="wiki-shell">
    <div class="sidebar-backdrop" aria-hidden="true"></div>
    <nav class="wiki-sidebar" id="wiki-sidebar" data-pagefind-ignore>
      <h3>Navigation</h3>
      <ul>
        <li><a href="/">Main page</a></li>
        <li><a href="/category/people">People</a></li>
        <li><a href="/category/organizations">Organizations</a></li>
        <li><a href="/category/places">Places</a></li>
        <li><a href="/category/programs">Programs</a></li>
        <li><a href="/category/procedures">Procedures</a></li>
        <li><a href="/category/events">Events</a></li>
        <li><a href="/on-this-day">On this day</a></li>
        <li><a href="/random">Random article</a></li>
      </ul>
      <h3>Site map</h3>
      <ul>
        <li><a href="/sources">Source index</a></li>
        <li><a href="/about">About</a></li>
      </ul>
      <h3>Tools</h3>
      <ul>
        <li><a href="/special/all-pages">All pages</a></li>
      </ul>
      <!-- Banner slot: desktop, bottom of left sidebar -->
      <div data-pagefind-ignore class="banner-slot banner-sidebar" data-banner="sidebar">
        <!-- BEGIN AADS AD UNIT 2438791 (sidebar placement) -->
        <div style="width: 100%; margin: auto; position: relative; z-index: 99998;">
          <iframe data-aa='2438791' src='//acceptable.a-ads.com/2438791/?size=Adaptive'
                  style='border:0; padding:0; width:100%; height:auto; overflow:hidden; display: block; margin: auto'></iframe>
        </div>
        <!-- END AADS AD UNIT 2438791 (sidebar placement) -->
      </div>
    </nav>

    <main class="wiki-main">
      <!-- Mobile-only inline banner, sits at the top of the main content area -->
      <div data-pagefind-ignore class="banner-slot banner-mobile" data-banner="mobile">
        <!-- BEGIN AADS AD UNIT 2438791 -->
        <iframe data-aa='2438791' src='//acceptable.a-ads.com/2438791/?size=Adaptive'
                style='border:0; padding:0; width:100%; height:60px; overflow:hidden; display:block'></iframe>
        <!-- END AADS AD UNIT 2438791 -->
      </div>
      <slot />
      <footer class="wiki-footer" data-pagefind-ignore>
        <div>KiriPedia is an independent project. All content is derived from John Kiriakou's publicly available statements — interviews, podcast appearances, video appearances, and short-form video content. This is not a neutral encyclopedia — it is the world as he describes it.</div>
        <ul>
          <li><a href="/about">About</a></li>
          <li><a href="/sources">Sources</a></li>
        </ul>
      </footer>
    </main>
  </div>
  <Analytics />

  {/* Header search typeahead — lazy-loads pagefind on first focus and shows
      live suggestions as you type. Wikipedia-style: title + short description,
      arrow-key navigation, Enter to navigate. */}
  <script is:inline>
    (function () {
      var input = document.getElementById('header-search-input');
      var box = document.getElementById('header-search-suggest');
      if (!input || !box) return;

      var pagefindPromise = null;
      function loadPagefind() {
        if (!pagefindPromise) {
          pagefindPromise = import('/pagefind/pagefind.js').then(function (mod) {
            mod.init && mod.init();
            return mod;
          }).catch(function () { return null; });
        }
        return pagefindPromise;
      }

      var selectedIdx = -1;
      var currentResults = [];
      var debounceTimer = null;

      function close() {
        box.hidden = true;
        box.innerHTML = '';
        selectedIdx = -1;
        currentResults = [];
      }

      function render(results) {
        currentResults = results;
        if (!results.length) {
          box.innerHTML = '<div class="ss-empty">No matches</div>';
          box.hidden = false;
          return;
        }
        box.innerHTML = results.map(function (r, i) {
          var safeTitle = (r.meta && r.meta.title) ? r.meta.title : r.url;
          var excerpt = r.excerpt || '';
          return (
            '<a class="ss-item' + (i === selectedIdx ? ' selected' : '') +
            '" href="' + r.url + '" data-idx="' + i + '">' +
              '<div class="ss-title">' + safeTitle + '</div>' +
              '<div class="ss-excerpt">' + excerpt + '</div>' +
            '</a>'
          );
        }).join('');
        box.hidden = false;
      }

      async function runSearch(q) {
        var pf = await loadPagefind();
        if (!pf) { close(); return; }
        try {
          var search = await pf.search(q);
          var top = search.results.slice(0, 7);
          var data = await Promise.all(top.map(function (r) { return r.data(); }));
          render(data);
        } catch (err) {
          close();
        }
      }

      input.addEventListener('input', function () {
        var q = input.value.trim();
        if (debounceTimer) clearTimeout(debounceTimer);
        if (q.length < 2) { close(); return; }
        debounceTimer = setTimeout(function () { runSearch(q); }, 130);
      });

      input.addEventListener('focus', function () {
        loadPagefind(); // warm the cache
        if (input.value.trim().length >= 2) runSearch(input.value.trim());
      });

      input.addEventListener('keydown', function (e) {
        if (box.hidden || !currentResults.length) {
          if (e.key === 'Escape') input.blur();
          return;
        }
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          selectedIdx = (selectedIdx + 1) % currentResults.length;
          render(currentResults);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          selectedIdx = (selectedIdx - 1 + currentResults.length) % currentResults.length;
          render(currentResults);
        } else if (e.key === 'Enter' && selectedIdx >= 0) {
          e.preventDefault();
          window.location.href = currentResults[selectedIdx].url;
        } else if (e.key === 'Escape') {
          close();
          input.blur();
        }
      });

      // Click outside closes the dropdown
      document.addEventListener('click', function (e) {
        if (!input.parentElement.contains(e.target)) close();
      });
    })();
  </script>

  <script is:inline>
    // Mobile sidebar toggle
    (function () {
      var btn = document.querySelector('.menu-btn');
      var sidebar = document.getElementById('wiki-sidebar');
      var backdrop = document.querySelector('.sidebar-backdrop');
      if (!btn || !sidebar) return;
      function setOpen(open) {
        sidebar.classList.toggle('open', open);
        if (backdrop) backdrop.classList.toggle('open', open);
        document.body.classList.toggle('sidebar-locked', open);
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      }
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        setOpen(!sidebar.classList.contains('open'));
      });
      if (backdrop) backdrop.addEventListener('click', function () { setOpen(false); });
      // Close on Escape
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') setOpen(false);
      });
      // Close on link click inside the sidebar
      sidebar.addEventListener('click', function (e) {
        var target = e.target;
        while (target && target !== sidebar) {
          if (target.tagName === 'A') { setOpen(false); break; }
          target = target.parentElement;
        }
      });
    })();
  </script>
</body>
</html>
