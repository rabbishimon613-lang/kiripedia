---
import '../styles/wiki.css';
const { title = 'KiriPedia' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — KiriPedia</title>
  <link rel="icon" href="/logo.svg" />
</head>
<body>
  <header class="wiki-header">
    <button class="menu-btn" aria-label="Menu">☰</button>
    <a href="/" class="logo-link">
      <img src="/logo.svg" alt="KiriPedia" class="logo-img" />
      <span class="wordmark">
        <span class="name">KiriPedia</span>
        <span class="tagline">The Free Encyclopedia of John Kiriakou's World</span>
      </span>
    </a>
    <!-- Banner slot: desktop, immediately to the left of the search bar -->
    <div class="banner-slot banner-header" data-banner="header">
      <!-- BEGIN AADS AD UNIT 2438715 -->
      <div style="width: 100%; margin: auto; position: relative; z-index: 99998;">
        <iframe data-aa='2438715' src='//acceptable.a-ads.com/2438715/?size=Adaptive'
                style='border:0; padding:0; width:100%; height:60px; overflow:hidden; display: block; margin: auto'></iframe>
      </div>
      <!-- END AADS AD UNIT 2438715 -->
    </div>
    <form class="search" role="search" action="/search" method="get">
      <input type="search" name="q" placeholder="Search KiriPedia" />
    </form>
  </header>

  <div class="wiki-shell">
    <nav class="wiki-sidebar">
      <h3>Navigation</h3>
      <ul>
        <li><a href="/">Main page</a></li>
        <li><a href="/category/people">People</a></li>
        <li><a href="/category/agencies">Agencies</a></li>
        <li><a href="/category/operations">Operations</a></li>
        <li><a href="/category/events">Events</a></li>
        <li><a href="/category/concepts">Concepts</a></li>
        <li><a href="/category/cases">Cases</a></li>
        <li><a href="/random">Random article</a></li>
      </ul>
      <h3>Site map</h3>
      <ul>
        <li><a href="/sources">Source index</a></li>
        <li><a href="/recent-changes">Recent changes</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/help">Help</a></li>
      </ul>
      <h3>Tools</h3>
      <ul>
        <li><a href="/special/all-pages">All pages</a></li>
        <li><a href="/special/stubs">Stubs</a></li>
      </ul>
      <!-- Banner slot: desktop, bottom of left sidebar -->
      <div class="banner-slot banner-sidebar" data-banner="sidebar">
        <!-- BEGIN AADS AD UNIT 2438715 (sidebar placement) -->
        <div style="width: 100%; margin: auto; position: relative; z-index: 99998;">
          <iframe data-aa='2438715' src='//acceptable.a-ads.com/2438715/?size=Adaptive'
                  style='border:0; padding:0; width:100%; height:auto; overflow:hidden; display: block; margin: auto'></iframe>
        </div>
        <!-- END AADS AD UNIT 2438715 (sidebar placement) -->
      </div>
    </nav>

    <main class="wiki-main">
      <slot />
      <footer class="wiki-footer">
        <div>KiriPedia is an independent project. All content is derived from John Kiriakou's public statements, interviews, podcast appearances, books, and transcripts. This is not a neutral encyclopedia — it is the world as he describes it.</div>
        <ul>
          <li><a href="/about">About</a></li>
          <li><a href="/disclaimer">Disclaimer</a></li>
          <li><a href="/sources">Sources</a></li>
        </ul>
      </footer>
    </main>
  </div>

  <!-- Banner slot: mobile, floating persistent at bottom of viewport -->
  <div class="banner-slot banner-mobile" data-banner="mobile">
    <!-- BEGIN AADS AD UNIT 2438716 -->
    <div style="position: absolute; z-index: 99999">
      <input autocomplete="off" type="checkbox" id="aadsstickympkax4ik" hidden />
      <div style="padding-top: 0; padding-bottom: auto;">
        <div style="width:100%;height:auto;position:fixed;text-align:center;font-size:0;bottom:0;left:0;right:0;margin:auto">
          <label for="aadsstickympkax4ik" style="top: 50%;transform: translateY(-50%);right:24px; position: absolute;border-radius: 4px; background: rgba(248, 248, 249, 0.70); padding: 4px;z-index: 99999;cursor:pointer">
            <svg fill="#000000" height="16px" width="16px" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 490 490">
              <polygon points="456.851,0 245,212.564 33.149,0 0.708,32.337 212.669,245.004 0.708,457.678 33.149,490 245,277.443 456.851,490 489.292,457.678 277.331,245.004 489.292,32.337 "/>
            </svg>
          </label>
          <div style="width: 100%;margin: auto;position: relative; z-index: 99998;"><iframe data-aa='2438716' src='//acceptable.a-ads.com/2438716/?size=Adaptive' style='border:0; padding:0; width:70%; height:auto; overflow:hidden; margin: auto'></iframe></div>
        </div>
        <style>
          #aadsstickympkax4ik:checked + div { display: none; }
        </style>
      </div>
    </div>
    <!-- END AADS AD UNIT 2438716 -->
  </div>
</body>
</html>
