---
import '../styles/wiki.css';
const { title = 'KiriPedia' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — KiriPedia</title>
  <link rel="icon" href="/logo.svg" />
</head>
<body>
  <header class="wiki-header">
    <button class="menu-btn" aria-label="Menu">☰</button>
    <a href="/" class="logo-link">
      <img src="/logo.svg" alt="KiriPedia" class="logo-img" />
      <span class="wordmark">
        <span class="name">KiriPedia</span>
        <span class="tagline">The Free Encyclopedia of John Kiriakou's World</span>
      </span>
    </a>
    <form class="search" role="search" action="/search" method="get">
      <input type="search" name="q" placeholder="Search KiriPedia" />
    </form>
    <!-- Banner slot: desktop, next to search bar. HTML drops in here. -->
    <div class="banner-slot banner-header" data-banner="header"></div>
  </header>

  <div class="wiki-shell">
    <nav class="wiki-sidebar">
      <h3>Navigation</h3>
      <ul>
        <li><a href="/">Main page</a></li>
        <li><a href="/category/people">People</a></li>
        <li><a href="/category/agencies">Agencies</a></li>
        <li><a href="/category/operations">Operations</a></li>
        <li><a href="/category/events">Events</a></li>
        <li><a href="/category/concepts">Concepts</a></li>
        <li><a href="/category/cases">Cases</a></li>
        <li><a href="/random">Random article</a></li>
      </ul>
      <h3>Site map</h3>
      <ul>
        <li><a href="/sources">Source index</a></li>
        <li><a href="/recent-changes">Recent changes</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/help">Help</a></li>
      </ul>
      <h3>Tools</h3>
      <ul>
        <li><a href="/special/all-pages">All pages</a></li>
        <li><a href="/special/stubs">Stubs</a></li>
      </ul>
      <!-- Banner slot: desktop, bottom of left sidebar. HTML drops in here. -->
      <div class="banner-slot banner-sidebar" data-banner="sidebar"></div>
    </nav>

    <main class="wiki-main">
      <slot />
      <footer class="wiki-footer">
        <div>KiriPedia is an independent project. All content is derived from John Kiriakou's public statements, interviews, podcast appearances, books, and transcripts. This is not a neutral encyclopedia — it is the world as he describes it.</div>
        <ul>
          <li><a href="/about">About</a></li>
          <li><a href="/disclaimer">Disclaimer</a></li>
          <li><a href="/sources">Sources</a></li>
        </ul>
      </footer>
    </main>
  </div>

  <!-- Banner slot: mobile, floating persistent at bottom of viewport. HTML drops in here. -->
  <div class="banner-slot banner-mobile" data-banner="mobile"></div>
</body>
</html>
