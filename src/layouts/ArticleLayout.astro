---
import WikiLayout from './WikiLayout.astro';
import References from '../components/References.astro';
const {
  title, subtitle, categories = [], image, slug,
  infobox, updated, datePublished,
} = Astro.props;

const SITE = 'https://www.kiripedia.org';
const articleURL = slug ? `${SITE}/wiki/${slug}` : undefined;
const isPerson = categories.includes('People');
const primaryCategory = categories[0];
const imageURL = image
  ? (image.startsWith('http') ? image : `${SITE}${image}`)
  : `${SITE}/og.png`;

// JSON-LD: Article — enriched with mainEntityOfPage, dateModified, articleSection,
// keywords (from categories), so Google can categorize the page properly.
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": subtitle ?? undefined,
  "image": imageURL,
  "url": articleURL,
  "mainEntityOfPage": articleURL,
  "inLanguage": "en",
  "articleSection": primaryCategory,
  "keywords": categories.join(', '),
  "datePublished": datePublished ?? '2025-01-01',
  "dateModified": updated ?? new Date().toISOString().slice(0, 10),
  "author": {
    "@type": "Organization",
    "name": "KiriPedia",
    "url": SITE,
  },
  "isPartOf": {
    "@type": "WebSite",
    "name": "KiriPedia",
    "url": SITE,
  },
  "publisher": {
    "@type": "Organization",
    "name": "KiriPedia",
    "logo": { "@type": "ImageObject", "url": `${SITE}/logo.png` },
  },
};

// Person schema for People-category articles. Pull jobTitle from the
// infobox if there's a Position/Role/Title-style key. Canon-safe: only
// uses what the article author already put in the infobox; no external
// data lookups.
function jobTitleFromInfobox(box) {
  if (!box?.data) return undefined;
  const candidateKeys = ['Position', 'Role', 'Title', 'Job title', 'Occupation', 'Vocation', 'Function'];
  for (const k of candidateKeys) {
    if (box.data[k]) return String(box.data[k]).replace(/\[(.+?)\]\(.+?\)/g, '$1');
  }
  return undefined;
}

const personSchema = isPerson ? {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": title,
  "description": subtitle ?? undefined,
  "image": image ? imageURL : undefined,
  "url": articleURL,
  "jobTitle": jobTitleFromInfobox(infobox),
  "mainEntityOfPage": articleURL,
} : null;

// Breadcrumbs: Main page › Category › Article
const breadcrumbItems = [
  { "@type": "ListItem", position: 1, name: "Main page", item: `${SITE}/` },
];
if (primaryCategory) {
  breadcrumbItems.push({
    "@type": "ListItem",
    position: 2,
    name: primaryCategory,
    item: `${SITE}/category/${primaryCategory.toLowerCase()}`,
  });
  breadcrumbItems.push({
    "@type": "ListItem",
    position: 3,
    name: title,
    item: articleURL,
  });
} else {
  breadcrumbItems.push({
    "@type": "ListItem",
    position: 2,
    name: title,
    item: articleURL,
  });
}
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems,
};
---
<WikiLayout
  title={title}
  description={subtitle ? `Per John Kiriakou: ${subtitle}` : `John Kiriakou's account of ${title}.`}
  image={image}
>
  <div class="wiki-content" data-pagefind-body>
    {/* JSON-LD structured data — Google reads these anywhere in the HTML */}
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    {personSchema && <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />}
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {/* Visible breadcrumb nav */}
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Main page</a>
      {primaryCategory && (
        <>
          <span class="sep">›</span>
          <a href={`/category/${primaryCategory.toLowerCase()}`}>{primaryCategory}</a>
        </>
      )}
      <span class="sep">›</span>
      <span class="current">{title}</span>
    </nav>

    <h1 class="firstHeading" data-pagefind-meta="title">{title}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
    <article class="wiki-body">
      <slot />
    </article>
    <References />
    {categories.length > 0 && (
      <div class="catlinks">
        <span class="label">Categories:</span>
        {categories.map((c) => <a href={`/category/${c.toLowerCase()}`}>{c}</a>)}
      </div>
    )}
  </div>
</WikiLayout>
